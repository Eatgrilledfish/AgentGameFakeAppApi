efs=q:string!@query(搜索关键词，必填);category:string@query;district:string@query|outputs=id,name,category,district,latitude,longitude|hints=地标模糊搜索。\\nget_landmark_by_id|GET /api/landmarks/{id}|intent=search|required=id|params=id|argdefs=id:string!@path(地标 ID，如 SS_001...)|outputs=id,name,category,district,latitude,longitude|hints=按地标 ID 查询详情。\\nget_landmark_stats|GET /api/landmarks/stats|intent=search|required=-|params=-|argdefs=-|outputs=total,by_category,by_district|hints=地标统计，不用于具体找房。\\nget_house_by_id|GET /api/houses/{house_id}|intent=house_detail|required=house_id|params=house_id|argdefs=house_id:string!@path(房源 ID，如 HF_200...)|outputs=house_id,listing_platform,rent,layout,area,district,community,subway_distance,commute_to_xierqi_min,status,tags,decoration,elevator,orientation,available_date|hints=单套房源详情。\\nget_house_listings|GET /api/houses/listings/{house_id}|intent=listings|required=house_id|params=house_id|argdefs=house_id:string!@path(房源 ID，如 HF_200...)|outputs=total,page_size,items[].listing_platform,items[].rent,items[].status,items[].url|hints=同一房源在多平台挂牌价格/状态查询。\\nget_houses_by_community|GET /api/houses/by_community|intent=search|required=community|params=community,listing_platform,page,page_size|argdefs=community:string!@query(小区名，与数据一致，如 建清...);listing_platform:string@query=链家/安居客/58同城;page:integer@query;page_size:integer@query|outputs=total,page_size,items[].house_id,items[].listing_platform,items[].rent,items[].layout,items[].district,items[].community,items[].subway_distance,items[].status|hints=给定小区名时优先。\\nget_houses_by_platform|GET /api/houses/by_platform|intent=search|required=-|params=listing_platform,district,area,min_price,max_price,bedrooms,rental_type,decoration,orientation,elevator,min_area,max_area,property_type,subway_line,max_subway_dist,subway_station,utilities_type,available_from_before,commute_to_xierqi_max,sort_by,sort_order,page,page_size|argdefs=listing_platform:string@query=链家/安居客/58同城;district:string@query;area:string@query;min_price:integer@query;max_price:integer@query;bedrooms:string@query;rental_type:string@query;decoration:string@query;orientation:string@query;elevator:string@query;min_area:integer@query;max_area:integer@query;property_type:string@query;subway_line:string@query;max_subway_dist:integer@query;subway_station:string@query;utilities_type:string@query;available_from_before:string@query;commute_to_xierqi_max:integer@query;sort_by:string@query;sort_order:string@query;page:integer@query;page_size:integer@query|outputs=total,page_size,items[].house_id,items[].listing_platform,items[].rent,items[].layout,items[].area,items[].district,items[].community,items[].subway_distance,items[].commute_to_xierqi_min,items[].status,items[].utilities_type|hints=泛化找房主入口；默认安居客。\\nget_nearby_landmarks|GET /api/houses/nearby_landmarks|intent=amenities|required=community|params=community,type,max_distance_m|argdefs=community:string!@query(小区名，用于定位基准点);type:string@query;max_distance_m:number@query|outputs=items[].name,items[].category,items[].distance_m|hints=查询小区周边商超/公园。\\nget_houses_nearby|GET /api/houses/nearby|intent=search|required=landmark_id|params=landmark_id,max_distance,listing_platform,page,page_size|argdefs=landmark_id:string!@query(地标 ID 或地标名称（支持...);max_distance:number@query;listing_platform:string@query=链家/安居客/58同城;page:integer@query;page_size:integer@query|outputs=total,page_size,items[].house_id,items[].listing_platform,items[].rent,items[].layout,items[].district,items[].community,items[].distance_to_landmark,items[].walking_distance,items[].walking_duration,items[].status|hints=按地标半径找房。\\nget_house_stats|GET /api/houses/stats|intent=search|required=-|params=-|argdefs=-|outputs=total,by_status,by_district,by_layout,price_ranges|hints=房源统计，不用于具体单房操作。\\nrent_house|POST /api/houses/{house_id}/rent|intent=rent|required=house_id,listing_platform|params=house_id,listing_platform|argdefs=house_id:string!@path(房源 ID，如 HF_200...);listing_platform:string!@query=链家/安居客/58同城(必填。明确租赁哪个平台；三平...)|outputs=house_id,listing_platform,status,message|hints=办理租房，必须指定平台。\\nterminate_rental|POST /api/houses/{house_id}/terminate|intent=terminate|required=house_id,listing_platform|params=house_id,listing_platform|argdefs=house_id:string!@path(房源 ID，如 HF_200...);listing_platform:string!@query=链家/安居客/58同城(必填。明确操作哪个平台；三平...)|outputs=house_id,listing_platform,status,message|hints=办理退租，必须指定平台。\\ntake_offline|POST /api/houses/{house_id}/offline|intent=offline|required=house_id,listing_platform|params=house_id,listing_platform|argdefs=house_id:string!@path(房源 ID，如 HF_200...);listing_platform:string!@query=链家/安居客/58同城(必填。明确操作哪个平台；三平...)|outputs=house_id,listing_platform,status,message|hints=办理下架，必须指定平台。\\nenums|listing_platform=链家,安居客,58同城;rental_type=整租,合租;landmark_category=subway,company,landmark;nearby_type=shopping,park;sort_by=price,area,subway;sort_order=asc,desc\"}, {\"role\": \"user\", \"content\": \"{\\\"history_summary\\\": \\\"\\\", \\\"context_facts\\\": {}, \\\"message\\\": \\\"记录日志\\\"}\"}], \"max_tokens\": 256, \"stream\": false}"}
