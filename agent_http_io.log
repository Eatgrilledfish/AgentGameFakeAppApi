T /api/houses/by_platform | 按挂牌平台筛选房源（平台可选） | 查询可租房源，支持按挂牌平台筛选。listing_platform 可选：不传则默认使用安居客；传 链家/安居客/58同城 则只返回该平台。调用时请求头必带 X-User-ID。\", \"parameters\": {\"type\": \"object\", \"properties\": {\"listing_platform\": {\"type\": \"string\", \"enum\": [\"链家\", \"安居客\", \"58同城\"], \"description\": \"in=query | 挂牌平台，可选。不传则默认安居客；传则仅返回该平台\"}, \"district\": {\"type\": \"string\", \"description\": \"in=query | 行政区，逗号分隔，如 海淀,朝阳\"}, \"area\": {\"type\": \"string\", \"description\": \"in=query | 商圈，逗号分隔，如 西二旗,上地\"}, \"min_price\": {\"type\": \"integer\", \"description\": \"in=query | 最低月租金（元）\"}, \"max_price\": {\"type\": \"integer\", \"description\": \"in=query | 最高月租金（元）\"}, \"bedrooms\": {\"type\": \"string\", \"description\": \"in=query | 卧室数，逗号分隔，如 1,2\"}, \"rental_type\": {\"type\": \"string\", \"description\": \"in=query | 整租 或 合租\"}, \"decoration\": {\"type\": \"string\", \"description\": \"in=query | 精装/简装 等\"}, \"orientation\": {\"type\": \"string\", \"description\": \"in=query | 朝向，如 朝南、南北\"}, \"elevator\": {\"type\": \"string\", \"description\": \"in=query | 是否有电梯：true/false\"}, \"min_area\": {\"type\": \"integer\", \"description\": \"in=query | 最小面积（平米）\"}, \"max_area\": {\"type\": \"integer\", \"description\": \"in=query | 最大面积（平米）\"}, \"property_type\": {\"type\": \"string\", \"description\": \"in=query | 物业类型，如 住宅\"}, \"subway_line\": {\"type\": \"string\", \"description\": \"in=query | 地铁线路，如 13号线\"}, \"max_subway_dist\": {\"type\": \"integer\", \"description\": \"in=query | 最大地铁距离（米），近地铁建议 800\"}, \"subway_station\": {\"type\": \"string\", \"description\": \"in=query | 地铁站名，如 车公庄站\"}, \"utilities_type\": {\"type\": \"string\", \"description\": \"in=query | 水电类型，如 民水民电\"}, \"available_from_before\": {\"type\": \"string\", \"description\": \"in=query | 可入住日期上限，YYYY-MM-DD（如 2026-03-10）\"}, \"commute_to_xierqi_max\": {\"type\": \"integer\", \"description\": \"in=query | 到西二旗通勤时间上限（分钟）\"}, \"sort_by\": {\"type\": \"string\", \"description\": \"in=query | 排序字段：pric